{
  "expo": {
    "name": "Ingilizce Kelimeler",
    "slug": "inglizce-kelimeler",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "inglizce-kelimeler",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Telaffuz kartlarinda kelime telaffuzunuzu kontrol etmek icin mikrofon kullanilir.",
        "NSSpeechRecognitionUsageDescription": "Telaffuz kartlarinda konusmanizi metne cevirmek icin ses tanima kullanilir."
      }
    },
    "android": {
      "permissions": [
        "RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.oktay10.inglizcekelimeler"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-notifications",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fda5efb7-6194-48e5-81c6-346a4ec9b042"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/fda5efb7-6194-48e5-81c6-346a4ec9b042"
    }
  }
}
