# AI Service API Key (OpenAI)
# Copy this file to ".env" and replace the placeholder with your real API key.
# Get your API key from https://platform.openai.com/api-keys
EXPO_PUBLIC_AI_API_KEY=your_key_here

# Groq API Key (Roleplay servisi için)
# Ücretsiz ve çok hızlı Llama 3 tabanlı API.
# API anahtarınızı https://console.groq.com/keys adresinden alabilirsiniz.
EXPO_PUBLIC_GROQ_API_KEY=your_groq_key_here
